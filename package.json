{
  "name": "syncup-crm",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "kill-port 4000 && turbo run build --filter=@syncup/shared && turbo run dev --filter=!@syncup/shared --filter=!@syncup/api-mock",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "db:migrate": "cd packages/api && npx prisma migrate dev",
    "db:generate": "cd packages/api && npx prisma generate",
    "db:seed": "cd packages/api && npx ts-node src/seed.ts"
  },
  "devDependencies": {
    "kill-port": "^2.0.1",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "overrides": {
    "@types/express": "^4.17.21",
    "@types/express-serve-static-core": "^4.17.43"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@11.13.0"
}
