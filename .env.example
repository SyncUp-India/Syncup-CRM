# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/syncup_crm"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Server
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# SMTP Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your-app-password
SMTP_FROM="SyncUp CRM <your@email.com>"

# Twilio (optional, for web click-to-call)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Expo Push Notifications
EXPO_ACCESS_TOKEN=

# Next.js Web
NEXT_PUBLIC_API_URL=http://localhost:4000/api
